From ad389aae8f1698c143ba7fd651a0bb9577b13454 Mon Sep 17 00:00:00 2001
From: Dev <dev@local>
Date: Wed, 22 Apr 2026 16:44:46 +0800
Subject: [PATCH 1/3] base-files: set default LAN IP to 192.168.1.1 for Xiaomi
 AX6000 dev

---
 package/base-files/files/bin/config_generate | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/package/base-files/files/bin/config_generate b/package/base-files/files/bin/config_generate
index 18fae05..439e113 100755
--- a/package/base-files/files/bin/config_generate
+++ b/package/base-files/files/bin/config_generate
@@ -163,7 +163,7 @@ generate_network() {
 		static)
 			local ipad netm prefix
 			case "$1" in
-				lan) ipad=${ipaddr:-"192.168.1.1"} ;;
+				lan) ipad=${ipaddr:-"192.168.1.1"} ;;
 				*) ipad=${ipaddr:-"192.168.$((addr_offset++)).1"} ;;
 			esac
 
