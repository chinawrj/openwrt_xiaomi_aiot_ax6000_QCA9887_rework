From 60d77f5a532b8622c178b8837409949b0fd7932d Mon Sep 17 00:00:00 2001
From: Dev <dev@local>
Date: Wed, 22 Apr 2026 17:32:54 +0800
Subject: [PATCH 2/3] arm64: dts: ipq5018-ax6000: revert pcie0 perst to
 GPIO_ACTIVE_LOW
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

GPIO_ACTIVE_HIGH was incorrect — it drives GPIO low on reset-deassert,
which keeps QCN9024 (ath11k) permanently in reset. Original ACTIVE_LOW
correctly releases PERST# by driving GPIO high.
---
 .../files/arch/arm64/boot/dts/qcom/ipq5018-ax6000.dts           | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/target/linux/qualcommax/files/arch/arm64/boot/dts/qcom/ipq5018-ax6000.dts b/target/linux/qualcommax/files/arch/arm64/boot/dts/qcom/ipq5018-ax6000.dts
index 207db08..8646593 100644
--- a/target/linux/qualcommax/files/arch/arm64/boot/dts/qcom/ipq5018-ax6000.dts
+++ b/target/linux/qualcommax/files/arch/arm64/boot/dts/qcom/ipq5018-ax6000.dts
@@ -529,7 +529,7 @@
 &pcie0 {
 	status = "okay";
 
-	perst-gpios = <&tlmm 15 GPIO_ACTIVE_HIGH>;
+perst-gpios = <&tlmm 15 GPIO_ACTIVE_LOW>;
 
 	pcie@0 {
 		wifi@0,0 {
-- 
2.43.0


From 339fc5cc3d7e978fe910716bddcc10ca5f79dc6a Mon Sep 17 00:00:00 2001
From: Dev <dev@local>
Date: Wed, 22 Apr 2026 17:46:33 +0800
Subject: [PATCH 3/3] arm64: dts: ipq5018-ax6000: fix pcie1 perst to
 GPIO_ACTIVE_HIGH

Stock firmware uses perst-gpio = <tlmm 18 0x00> (flag 0 = ACTIVE_HIGH)
for pcie1. ACTIVE_LOW kept the QCA9887 in reset because the GPIO
was driven high on reset-deassert instead of low.

Stock DTS reference:
  pcie1 (x1): perst-gpio = <0x06 0x12 0x00>  -> ACTIVE_HIGH
  pcie0 (x2): perst-gpio = <0x06 0x0f 0x01>  -> ACTIVE_LOW
---
 .../files/arch/arm64/boot/dts/qcom/ipq5018-ax6000.dts           | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/target/linux/qualcommax/files/arch/arm64/boot/dts/qcom/ipq5018-ax6000.dts b/target/linux/qualcommax/files/arch/arm64/boot/dts/qcom/ipq5018-ax6000.dts
index 8646593..7ea0c03 100644
--- a/target/linux/qualcommax/files/arch/arm64/boot/dts/qcom/ipq5018-ax6000.dts
+++ b/target/linux/qualcommax/files/arch/arm64/boot/dts/qcom/ipq5018-ax6000.dts
@@ -551,7 +551,7 @@ perst-gpios = <&tlmm 15 GPIO_ACTIVE_LOW>;
 &pcie1 {
 	status = "okay";
 
-	perst-gpios = <&tlmm 18 GPIO_ACTIVE_LOW>;
+perst-gpios = <&tlmm 18 GPIO_ACTIVE_HIGH>;
 
 	pcie@0 {
 		wifi@0,0 {
-- 
2.43.0

