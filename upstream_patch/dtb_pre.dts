	thermal-zones {

		cpu-thermal {
			thermal-sensors = <0x39 0x02>;

			trips {

				cpu-critical {
					temperature = <0x1d4c0>;
					hysteresis = <0x3e8>;
					type = "critical";
				};

				cpu-passive {
					temperature = <0x186a0>;
					hysteresis = <0x3e8>;
					type = "passive";
					phandle = <0x3a>;
				};
			};

			cooling-maps {

				map0 {
					trip = <0x3a>;
					cooling-device = <0x3b 0xffffffff 0xffffffff 0x3c 0xffffffff 0xffffffff>;
				};
			};
		};

		gephy-thermal {
			thermal-sensors = <0x39 0x04>;

			trips {

				gephy-critical {
					temperature = <0x1d4c0>;
					hysteresis = <0x3e8>;
					type = "critical";
				};
			};
		};

		top-glue-thermal {
			thermal-sensors = <0x39 0x03>;

			trips {

				top-glue-critical {
					temperature = <0x1d4c0>;
					hysteresis = <0x3e8>;
					type = "critical";
				};
			};
		};

		ubi32-thermal {
			thermal-sensors = <0x39 0x01>;

			trips {

				ubi32-critical {
					temperature = <0x1d4c0>;
					hysteresis = <0x3e8>;
					type = "critical";
				};
			};
		};
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = <0x01 0x02 0xf08 0x01 0x03 0xf08 0x01 0x04 0xf08 0x01 0x01 0xf08>;
	};

	smp2p-wcss {
		compatible = "qcom,smp2p";
		qcom,smem = <0x1b3 0x1ac>;
		interrupt-parent = <0x01>;
		interrupts = <0x00 0xb1 0x01>;
		mboxes = <0x05 0x09>;
		qcom,local-pid = <0x00>;
		qcom,remote-pid = <0x01>;

		master-kernel {
			qcom,entry-name = "master-kernel";
			#qcom,smem-state-cells = <0x01>;
			phandle = <0x2f>;
		};

		slave-kernel {
			qcom,entry-name = "slave-kernel";
			interrupt-controller;
			#interrupt-cells = <0x02>;
			phandle = <0x2e>;
		};
	};

	aliases {
		label-mac-device = "/soc@0/dp1";
		led-boot = "/leds/system-blue";
		led-failsafe = "/leds/system-yellow";
		led-running = "/leds/system-blue";
		led-upgrade = "/leds/system-yellow";
		serial0 = "/soc@0/serial@78af000";
	};

	chosen {
		bootargs-append = " ubi.mtd=rootfs root=/dev/ubiblock0_0 coherent_pool=2M";
		stdout-path = "serial0:115200n8";
	};

	keys {
		compatible = "gpio-keys";
		pinctrl-0 = <0x3d>;
		pinctrl-names = "default";

		reset-button {
			label = "reset";
			gpios = <0x0b 0x26 0x01>;
			linux,code = <0x198>;
		};
	};

	leds {
		compatible = "gpio-leds";
		pinctrl-0 = <0x3e>;
		pinctrl-names = "default";

		wlan-green {
			color = <0x02>;
			function = "wlan";
			gpios = <0x0b 0x17 0x00>;
		};

		system-blue {
			color = <0x03>;
			function = "power";
			gpios = <0x0b 0x18 0x00>;
		};

		system-yellow {
			color = <0x06>;
			function = "power";
			gpios = <0x0b 0x19 0x00>;
		};

		net-blue {
			color = <0x03>;
			function = "wan-online";
			gpios = <0x0b 0x1a 0x00>;
		};

		net-yellow {
			color = <0x06>;
			function = "wan";
			gpios = <0x0b 0x1b 0x00>;
		};

		phy-green {
			color = <0x02>;
			function = "lan";
			gpios = <0x0b 0x1c 0x00>;
		};
	};
};
