/dts-v1/;

/ {
	interrupt-parent = <0x01>;
	#address-cells = <0x02>;
	#size-cells = <0x02>;
	model = "Xiaomi AX6000";
	compatible = "xiaomi,ax6000", "qcom,ipq5018";

	clocks {

		gephy-rx-clk {
			compatible = "fixed-clock";
			clock-frequency = <0x7735940>;
			#clock-cells = <0x00>;
			phandle = <0x24>;
		};

		gephy-tx-clk {
			compatible = "fixed-clock";
			clock-frequency = <0x7735940>;
			#clock-cells = <0x00>;
			phandle = <0x25>;
		};

		ref-96mhz-clk {
			compatible = "fixed-factor-clock";
			clocks = <0x02>;
			#clock-cells = <0x00>;
			clock-div = <0x01>;
			clock-mult = <0x02>;
			phandle = <0x03>;
		};

		sleep-clk {
			compatible = "fixed-clock";
			#clock-cells = <0x00>;
			clock-frequency = <0x7d00>;
			phandle = <0x21>;
		};

		xo-board-clk {
			compatible = "fixed-factor-clock";
			clocks = <0x03>;
			#clock-cells = <0x00>;
			clock-div = <0x04>;
			clock-mult = <0x01>;
			phandle = <0x20>;
		};

		xo-clk {
			compatible = "fixed-clock";
			#clock-cells = <0x00>;
			clock-frequency = <0x2dc6c00>;
			phandle = <0x02>;
		};
	};

	cpus {
		#address-cells = <0x01>;
		#size-cells = <0x00>;

		cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x00>;
			enable-method = "psci";
			next-level-cache = <0x04>;
			clocks = <0x05 0x01>;
			operating-points-v2 = <0x06>;
			#cooling-cells = <0x02>;
			phandle = <0x3b>;
		};

		cpu@1 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x01>;
			enable-method = "psci";
			next-level-cache = <0x04>;
			clocks = <0x05 0x01>;
			operating-points-v2 = <0x06>;
			#cooling-cells = <0x02>;
			phandle = <0x3c>;
		};

		l2-cache {
			compatible = "cache";
			cache-level = <0x02>;
			cache-size = <0x80000>;
			cache-unified;
			phandle = <0x04>;
		};
	};

	opp-table-cpu {
		compatible = "operating-points-v2";
		opp-shared;
		phandle = <0x06>;

		opp-1008000000 {
			opp-hz = <0x00 0x3c14dc00>;
			opp-microvolt = <0x10c8e0>;
			clock-latency-ns = <0x30d40>;
		};
	};

	firmware {

		scm {
			compatible = "qcom,scm-ipq5018", "qcom,scm";
			qcom,dload-mode = <0x07 0x6100>;
			qcom,sdi-enabled;
		};
	};

	memory@40000000 {
		device_type = "memory";
		reg = <0x00 0x40000000 0x00 0x00>;
	};

	pmu {
		compatible = "arm,cortex-a53-pmu";
		interrupts = <0x01 0x07 0xf04>;
	};

	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};

	reserved-memory {
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		tz_apps@4a400000 {
			reg = <0x00 0x4a400000 0x00 0x400000>;
			no-map;
		};

		bootloader@4a800000 {
			reg = <0x00 0x4a800000 0x00 0x200000>;
			no-map;
		};

		sbl@4aa00000 {
			reg = <0x00 0x4aa00000 0x00 0x100000>;
			no-map;
		};

		smem@4ab00000 {
			compatible = "qcom,smem";
			reg = <0x00 0x4ab00000 0x00 0x100000>;
			no-map;
			hwlocks = <0x08 0x03>;
		};

		tz@4ac00000 {
			reg = <0x00 0x4ac00000 0x00 0x200000>;
			no-map;
		};

		wcss@4b000000 {
			reg = <0x00 0x4b000000 0x00 0x1b00000>;
			no-map;
			phandle = <0x30>;
		};
	};

	soc@0 {
		compatible = "simple-bus";
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges = <0x00 0x00 0x00 0xffffffff>;

		phy@5b000 {
			compatible = "qcom,ipq5018-usb-hsphy";
			reg = <0x5b000 0x120>;
			clocks = <0x09 0x77>;
			resets = <0x09 0x4f>;
			#phy-cells = <0x00>;
			status = "disabled";
			phandle = <0x2b>;
		};

		phy@7e000 {
			compatible = "qcom,ipq5018-uniphy-pcie-phy";
			reg = <0x7e000 0x800>;
			clocks = <0x09 0x42>;
			resets = <0x09 0x2f 0x09 0x30>;
			#clock-cells = <0x00>;
			#phy-cells = <0x00>;
			num-lanes = <0x01>;
			status = "okay";
			phandle = <0x23>;
		};

		phy@86000 {
			compatible = "qcom,ipq5018-uniphy-pcie-phy";
			reg = <0x86000 0x1000>;
			clocks = <0x09 0x3c>;
			resets = <0x09 0x23 0x09 0x24>;
			#clock-cells = <0x00>;
			#phy-cells = <0x00>;
			num-lanes = <0x02>;
			status = "okay";
			phandle = <0x22>;
		};

		mdio@88000 {
			compatible = "qcom,ipq5018-mdio", "qcom,ipq40xx-mdio";
			reg = <0x88000 0x64 0x19475c4 0x04>;
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			clocks = <0x09 0x35>;
			clock-names = "gcc_mdio_ahb_clk";
			status = "okay";
			phandle = <0x33>;

			ethernet-phy@7 {
				compatible = "ethernet-phy-id004d.d0c0";
				reg = <0x07>;
				resets = <0x09 0x6f>;
				qcom,dac-preset-short-cable;
				phandle = <0x35>;
			};
		};

		mdio@90000 {
			compatible = "qcom,ipq5018-mdio";
			reg = <0x90000 0x64>;
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			clocks = <0x09 0x36>;
			clock-names = "gcc_mdio_ahb_clk";
			status = "okay";
			pinctrl-0 = <0x0a>;
			pinctrl-names = "default";
			reset-gpios = <0x0b 0x27 0x01>;
			phandle = <0x34>;

			ethernet-phy@0 {
				reg = <0x00>;
				phandle = <0x0c>;
			};

			ethernet-phy@1 {
				reg = <0x01>;
				phandle = <0x0d>;
			};

			ethernet-phy@2 {
				reg = <0x02>;
				phandle = <0x0e>;
			};

			ethernet-phy@3 {
				reg = <0x03>;
				phandle = <0x0f>;
			};

			ethernet-phy@8 {
				compatible = "ethernet-phy-id004d.d101";
				reg = <0x08>;
				phandle = <0x37>;

				leds {
					#address-cells = <0x01>;
					#size-cells = <0x00>;

					led@0 {
						reg = <0x00>;
						color = <0x02>;
						function = "wan";
						default-state = "keep";
					};
				};
			};

			ethernet-switch@11 {
				compatible = "qca,qca8337";
				reg = <0x11>;

				ports {
					#address-cells = <0x01>;
					#size-cells = <0x00>;

					port@1 {
						reg = <0x01>;
						label = "lan1";
						phy-handle = <0x0c>;

						leds {
							#address-cells = <0x01>;
							#size-cells = <0x00>;

							led@0 {
								reg = <0x00>;
								color = <0x02>;
								function = "lan";
								default-state = "keep";
							};
						};
					};

					port@2 {
						reg = <0x02>;
						label = "lan2";
						phy-handle = <0x0d>;

						leds {
							#address-cells = <0x01>;
							#size-cells = <0x00>;

							led@0 {
								reg = <0x00>;
								color = <0x02>;
								function = "lan";
								default-state = "keep";
							};
						};
					};

					port@3 {
						reg = <0x03>;
						label = "lan3";
						phy-handle = <0x0e>;

						leds {
							#address-cells = <0x01>;
							#size-cells = <0x00>;

							led@0 {
								reg = <0x00>;
								color = <0x02>;
								function = "lan";
								default-state = "keep";
							};
						};
					};

					port@4 {
						reg = <0x04>;
						phy-handle = <0x0f>;
						phy-mode = "gmii";
						ethernet = <0x10>;
					};
				};
			};
		};

		clock-controller@9b000 {
			compatible = "qcom,ipq5018-cmn-pll";
			reg = <0x9b000 0x800>;
			clocks = <0x03 0x09 0x1d 0x09 0x1e>;
			clock-names = "ref", "ahb", "sys";
			#clock-cells = <0x01>;
			assigned-clocks = <0x11 0x00>;
			assigned-clock-rates-u64 = <0x01 0x1e1a3000>;
			phandle = <0x11>;
		};

		qfprom@a0000 {
			compatible = "qcom,ipq5018-qfprom", "qcom,qfprom";
			reg = <0xa0000 0x1000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			status = "okay";

			mode@249 {
				reg = <0x249 0x01>;
				bits = <0x00 0x03>;
				phandle = <0x12>;
			};

			base1@249 {
				reg = <0x249 0x02>;
				bits = <0x03 0x08>;
				phandle = <0x13>;
			};

			base2@24a {
				reg = <0x24a 0x02>;
				bits = <0x03 0x08>;
				phandle = <0x14>;
			};

			s0-p1@24b {
				reg = <0x24b 0x02>;
				bits = <0x02 0x06>;
				phandle = <0x15>;
			};

			s0-p2@24c {
				reg = <0x24c 0x01>;
				bits = <0x01 0x06>;
				phandle = <0x16>;
			};

			s1-p1@24c {
				reg = <0x24c 0x02>;
				bits = <0x07 0x06>;
				phandle = <0x17>;
			};

			s1-p2@24d {
				reg = <0x24d 0x02>;
				bits = <0x05 0x06>;
				phandle = <0x18>;
			};

			s2-p1@24e {
				reg = <0x24e 0x02>;
				bits = <0x03 0x06>;
				phandle = <0x19>;
			};

			s2-p2@24f {
				reg = <0x24f 0x01>;
				bits = <0x01 0x06>;
				phandle = <0x1a>;
			};

			s3-p1@24f {
				reg = <0x24f 0x02>;
				bits = <0x07 0x06>;
				phandle = <0x1b>;
			};

			s3-p2@250 {
				reg = <0x250 0x02>;
				bits = <0x05 0x06>;
				phandle = <0x1c>;
			};

			s4-p1@251 {
				reg = <0x251 0x02>;
				bits = <0x03 0x06>;
				phandle = <0x1d>;
			};

			s4-p2@254 {
				reg = <0x254 0x01>;
				bits = <0x00 0x06>;
				phandle = <0x1e>;
			};
		};

		rng@e3000 {
			compatible = "qcom,prng-ee";
			reg = <0xe3000 0x1000>;
			clocks = <0x09 0x43>;
			clock-names = "core";
			status = "okay";
		};

		thermal-sensor@4a9000 {
			compatible = "qcom,ipq5018-tsens";
			reg = <0x4a9000 0x1000 0x4a8000 0x1000>;
			nvmem-cells = <0x12 0x13 0x14 0x15 0x16 0x17 0x18 0x19 0x1a 0x1b 0x1c 0x1d 0x1e>;
			nvmem-cell-names = "mode", "base1", "base2", "s0_p1", "s0_p2", "s1_p1", "s1_p2", "s2_p1", "s2_p2", "s3_p1", "s3_p2", "s4_p1", "s4_p2";
			interrupts = <0x00 0xb8 0x01>;
			interrupt-names = "uplow";
			#qcom,sensors = <0x05>;
			#thermal-sensor-cells = <0x01>;
			phandle = <0x39>;
		};

		dma-controller@704000 {
			compatible = "qcom,bam-v1.7.4", "qcom,bam-v1.7.0";
			reg = <0x704000 0x20000>;
			interrupts = <0x00 0xcf 0x04>;
			clocks = <0x09 0x1f>;
			clock-names = "bam_clk";
			#dma-cells = <0x01>;
			qcom,ee = <0x01>;
			qcom,controlled-remotely;
			status = "okay";
			phandle = <0x1f>;
		};

		crypto@73a000 {
			compatible = "qcom,crypto-v5.1";
			reg = <0x73a000 0x6000>;
			clocks = <0x09 0x1f 0x09 0x20 0x09 0x21>;
			clock-names = "iface", "bus", "core";
			dmas = <0x1f 0x02 0x1f 0x03>;
			dma-names = "rx", "tx";
			status = "okay";
		};

		pinctrl@1000000 {
			compatible = "qcom,ipq5018-tlmm";
			reg = <0x1000000 0x300000>;
			interrupts = <0x00 0xd0 0x04>;
			gpio-controller;
			#gpio-cells = <0x02>;
			gpio-ranges = <0x0b 0x00 0x00 0x2f>;
			interrupt-controller;
			#interrupt-cells = <0x02>;
			phandle = <0x0b>;

			uart1-state {
				pins = "gpio31", "gpio32", "gpio33", "gpio34";
				function = "blsp1_uart1";
				drive-strength = <0x08>;
				bias-pull-down;
			};

			button-state {
				pins = "gpio38";
				function = "gpio";
				drive-strength = <0x08>;
				bias-pull-up;
				phandle = <0x3d>;
			};

			leds-state {
				pins = "gpio23", "gpio24", "gpio25", "gpio26", "gpio27", "gpio28";
				function = "gpio";
				drive-strength = <0x08>;
				bias-pull-down;
				phandle = <0x3e>;
			};

			mdio-state {
				phandle = <0x0a>;

				mdc-pins {
					pins = "gpio36";
					function = "mdc";
					drive-strength = <0x08>;
					bias-pull-up;
				};

				mdio-pins {
					pins = "gpio37";
					function = "mdio";
					drive-strength = <0x08>;
					bias-pull-up;
				};
			};

			qpic-state {
				phandle = <0x29>;

				clock-pins {
					pins = "gpio9";
					function = "qspi_clk";
					drive-strength = <0x08>;
					bias-disable;
				};

				cs-pins {
					pins = "gpio8";
					function = "qspi_cs";
					drive-strength = <0x08>;
					bias-disable;
				};

				data-pins {
					pins = "gpio4", "gpio5", "gpio6", "gpio7";
					function = "qspi_data";
					drive-strength = <0x08>;
					bias-disable;
				};
			};

			uart0-state {
				pins = "gpio20", "gpio21";
				function = "blsp0_uart0";
				bias-disable;
				phandle = <0x26>;
			};
		};

		clock-controller@1800000 {
			compatible = "qcom,gcc-ipq5018";
			reg = <0x1800000 0x80000>;
			clocks = <0x20 0x21 0x22 0x23 0x00 0x24 0x25 0x00 0x00>;
			#clock-cells = <0x01>;
			#reset-cells = <0x01>;
			phandle = <0x09>;
		};

		hwlock@1905000 {
			compatible = "qcom,tcsr-mutex";
			reg = <0x1905000 0x20000>;
			#hwlock-cells = <0x01>;
			phandle = <0x08>;
		};

		syscon@1937000 {
			compatible = "qcom,tcsr-ipq5018", "syscon";
			reg = <0x1937000 0x21000>;
			phandle = <0x07>;
		};

		pwm@1941010 {
			compatible = "qcom,ipq5018-pwm", "qcom,ipq6018-pwm";
			reg = <0x1941010 0x20>;
			clocks = <0x09 0x12>;
			assigned-clocks = <0x09 0x12>;
			assigned-clock-rates = <0x5f5e100>;
			#pwm-cells = <0x02>;
			status = "disabled";
		};

		mmc@7804000 {
			compatible = "qcom,ipq5018-sdhci", "qcom,sdhci-msm-v5";
			reg = <0x7804000 0x1000>;
			reg-names = "hc";
			interrupts = <0x00 0x7b 0x04 0x00 0x8a 0x04>;
			interrupt-names = "hc_irq", "pwr_irq";
			clocks = <0x09 0x59 0x09 0x5a 0x20>;
			clock-names = "iface", "core", "xo";
			non-removable;
			status = "disabled";
		};

		dma-controller@7884000 {
			compatible = "qcom,bam-v1.7.0";
			reg = <0x7884000 0x1d000>;
			interrupts = <0x00 0xee 0x04>;
			clocks = <0x09 0x13>;
			clock-names = "bam_clk";
			#dma-cells = <0x01>;
			qcom,ee = <0x00>;
			phandle = <0x27>;
		};

		serial@78af000 {
			compatible = "qcom,msm-uartdm-v1.4", "qcom,msm-uartdm";
			reg = <0x78af000 0x200>;
			interrupts = <0x00 0x6b 0x04>;
			clocks = <0x09 0x1a 0x09 0x13>;
			clock-names = "core", "iface";
			status = "okay";
			pinctrl-0 = <0x26>;
			pinctrl-names = "default";
		};

		serial@78b0000 {
			compatible = "qcom,msm-uartdm-v1.4", "qcom,msm-uartdm";
			reg = <0x78b0000 0x200>;
			interrupts = <0x00 0x6c 0x04>;
			clocks = <0x09 0x1b 0x09 0x13>;
			clock-names = "core", "iface";
			status = "disabled";
		};

		spi@78b5000 {
			compatible = "qcom,spi-qup-v2.2.1";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			reg = <0x78b5000 0x600>;
			interrupts = <0x00 0x5f 0x04>;
			clocks = <0x09 0x15 0x09 0x13>;
			clock-names = "core", "iface";
			dmas = <0x27 0x04 0x27 0x05>;
			dma-names = "tx", "rx";
			status = "disabled";
		};

		i2c@78b7000 {
			compatible = "qcom,i2c-qup-v2.2.1";
			reg = <0x78b7000 0x600>;
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			interrupts = <0x00 0x61 0x04>;
			clocks = <0x09 0x18 0x09 0x13>;
			clock-names = "core", "iface";
			clock-frequency = <0x61a80>;
			dmas = <0x27 0x09 0x27 0x08>;
			dma-names = "tx", "rx";
			status = "disabled";
		};

		dma-controller@7984000 {
			compatible = "qcom,bam-v1.7.4", "qcom,bam-v1.7.0";
			reg = <0x7984000 0x1c000>;
			interrupts = <0x00 0x92 0x04>;
			clocks = <0x09 0x56>;
			clock-names = "bam_clk";
			#dma-cells = <0x01>;
			qcom,ee = <0x00>;
			status = "okay";
			phandle = <0x28>;
		};

		spi@79b0000 {
			compatible = "qcom,ipq5018-snand", "qcom,ipq9574-snand";
			reg = <0x79b0000 0x10000>;
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			clocks = <0x09 0x57 0x09 0x56 0x09 0x58>;
			clock-names = "core", "aon", "iom";
			dmas = <0x28 0x00 0x28 0x01 0x28 0x02>;
			dma-names = "tx", "rx", "cmd";
			status = "okay";
			pinctrl-0 = <0x29>;
			pinctrl-names = "default";
			phandle = <0x2a>;

			nand@0 {
				compatible = "spi-nand";
				reg = <0x00>;
				nand-ecc-engine = <0x2a>;
				nand-bus-width = <0x08>;

				partitions {
					compatible = "fixed-partitions";
					#address-cells = <0x01>;
					#size-cells = <0x01>;

					partition@0 {
						label = "0:sbl1";
						reg = <0x00 0x80000>;
						read-only;
					};

					partition@80000 {
						label = "0:mibib";
						reg = <0x80000 0x80000>;
						read-only;
					};

					partition@100000 {
						label = "0:bootconfig";
						reg = <0x100000 0x40000>;
						read-only;
					};

					partition@140000 {
						label = "0:bootconfig1";
						reg = <0x140000 0x40000>;
						read-only;
					};

					partition@180000 {
						label = "0:qsee";
						reg = <0x180000 0x100000>;
						read-only;
					};

					partition@280000 {
						label = "0:qsee_1";
						reg = <0x280000 0x100000>;
						read-only;
					};

					partition@380000 {
						label = "0:devcfg";
						reg = <0x380000 0x40000>;
						read-only;
					};

					partition@3c0000 {
						label = "0:devcfg_1";
						reg = <0x3c0000 0x40000>;
						read-only;
					};

					partition@400000 {
						label = "0:cdt";
						reg = <0x400000 0x40000>;
						read-only;
					};

					partition@440000 {
						label = "0:cdt_1`";
						reg = <0x440000 0x40000>;
						read-only;
					};

					partition@480000 {
						label = "0:appsblenv";
						reg = <0x480000 0x80000>;
					};

					partition@500000 {
						label = "0:appsbl";
						reg = <0x500000 0x140000>;
						read-only;
					};

					partition@640000 {
						label = "0:appsbl_1";
						reg = <0x640000 0x140000>;
						read-only;
					};

					partition@780000 {
						label = "0:art";
						reg = <0x780000 0x100000>;
						read-only;

						nvmem-layout {
							compatible = "fixed-layout";
							#address-cells = <0x01>;
							#size-cells = <0x01>;

							macaddr@0 {
								reg = <0x00 0x06>;
								phandle = <0x36>;
							};

							macaddr@6 {
								reg = <0x06 0x06>;
								phandle = <0x38>;
							};

							caldata@4d000 {
								reg = <0x4d000 0x844>;
								phandle = <0x32>;
							};
						};
					};

					partition@880000 {
						label = "0:training";
						reg = <0x880000 0x80000>;
						read-only;
					};

					partition@900000 {
						label = "bdata";
						reg = <0x900000 0x80000>;
					};

					partition@980000 {
						label = "crash";
						reg = <0x980000 0x80000>;
					};

					partition@a00000 {
						label = "crash_syslog";
						reg = <0xa00000 0x80000>;
					};

					partition@a80000 {
						label = "ubi_kernel";
						reg = <0xa80000 0x2400000>;
					};

					partition@2e80000 {
						label = "rootfs";
						reg = <0x2e80000 0x5180000>;
					};
				};
			};
		};

		usb@8af8800 {
